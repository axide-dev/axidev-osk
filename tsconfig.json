{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Node16",
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "node16",
    "resolveJsonModule": true
  },
  "include": ["forge.env.d.ts", "src/**/*.ts", "src/**/*.tsx", "vite*.config.mts"],
  "exclude": ["dist", "node_modules"]
}
